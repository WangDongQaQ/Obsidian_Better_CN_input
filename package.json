{
  "name": "obsidian-better-cn-input",
  "version": "0.2.1",
  "description": "Better Chinese input ergonomics for Obsidian Markdown editing.",
  "main": "main.js",
  "scripts": {
    "build": "tsc --noEmit --skipLibCheck && node esbuild.config.mjs production",
    "dev": "node esbuild.config.mjs",
    "test": "vitest run",
    "typecheck": "tsc --noEmit --skipLibCheck"
  },
  "keywords": [
    "obsidian",
    "markdown",
    "chinese-input-method",
    "codemirror",
    "paragraph-selection"
  ],
  "license": "MIT",
  "devDependencies": {
    "@codemirror/state": "6.5.0",
    "@codemirror/view": "6.38.6",
    "@types/node": "^24.0.3",
    "builtin-modules": "^5.0.0",
    "esbuild": "^0.25.5",
    "obsidian": "1.13.1",
    "tslib": "^2.8.1",
    "typescript": "^5.8.3",
    "vitest": "^3.2.4"
  }
}
